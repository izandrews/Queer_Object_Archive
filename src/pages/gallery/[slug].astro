---
import { getCollection, render } from 'astro:content';
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const gallery = await getCollection('gallery');

  return gallery.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const BASE = import.meta.env.BASE_URL;

const object_number = 16;
const { item } = Astro.props;

const slug = item.id;
const { Content } = await render(item);

// extract number from "object-12"
const match = slug.match(/\d+$/);
const num = match ? parseInt(match[0]) : null;

let prev;
prev = num - 1;
if( prev< 10){
  prev = prev = num && num > 1 ? `object-0${num - 1}` : null;
} else {
  prev = num && num > 1 ? `object-${num - 1}` : null;
};
let next;
next = num + 1;
if(next < 10){
  next = num ? `object-0${num + 1}` : null;
} else {
  next = num ? `object-${num + 1}` : null;
};

if(num == 1){
  prev = `object-${object_number}`;
};
if(num == object_number){
  next = "object-01";
};

const note_colours = ["y", "b", "g", "p"]
  .sort(() => Math.random() - 0.5);

const [colour1, colour2, colour3] = note_colours;

const main = `${BASE}gallery/${slug}/main.webp`;
const portrait = `${BASE}gallery/${slug}/portrait.webp`;
const card = `${BASE}gallery/${slug}/card.webp`;
---
<Layout>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- <title>{item.data.title}</title> -->
  </head>

  <body>
    <script define:vars={{ num, object_number }}>
      window.doRandom = function (){
      let randomNumber;

      do {
        randomNumber = Math.floor(Math.random() * object_number) + 1;
      }while (randomNumber === num);
      if(randomNumber < 10){
        randomNumber = "0" + randomNumber;
      }
      const randomPage = "object-" + randomNumber;
      window.location.href = `${BASE}gallery/${randomPage}`;

      };

      window.doCheck = function() {
        // Get the checkbox
        console.log("doCheck running")
        var checkBox = document.getElementById("myCheck");
        // Get the output text
        var text = document.getElementById("text");
        // If the checkbox is checked, display the output text
        if (checkBox.checked == true){
          text.style.display = "block";
          card.style.display = "none";
        } else {
          text.style.display = "none";
          card.style.display = "block";
        }
      };

    </script>

    <!-- <h1>{item.data.title}</h1> -->

    <!--{item.data.description && <p>{item.data.description}</p>} -->

    <header class="object-header">
      <a href={BASE} class="title-link" ><img src={`${BASE}title.webp`} alt="Queer Object Archive" class="title-image" /></a>

      <a href={`${BASE}gallery/${prev}`} class="nav-link-left">
        <img src={`${BASE}prev_${colour2}.webp`} alt="prev" class="sticky-note" />
      </a>

      <img src={main} alt="" class="main-image" />


      <a href={`${BASE}gallery/${next}`} class="nav-link-right">
        <img src={`${BASE}next_${colour3}.webp`} alt="next" class="sticky-note" />
      </a>
      <div id="nav-link-random"> 
      <img src={`${BASE}RANDOM_${colour1}.webp`} alt="Random object" class="sticky-note" onclick="doRandom()"/>
      </div>
    </header>

    

    <div class="images">
      <div class = "controls">
      <img src={`${BASE}mspaint2.webp`} id="left-icon" class="side-icon" />
      <label class="switch">
        <input type="checkbox" id="myCheck" onclick="doCheck()">
        <span class="slider round"></span>
      </label>
      <img src={`${BASE}mspaint1.webp`} id= "slider" class="side-icon" />
      </div>

      <section class="portrait">
        <img src={portrait} alt="" />
      </section>

      <section class="card-text">
        <img src={card} alt="" id="card" />
        <!--  <p id="text" class="text" style="display:none">
          {item.body}
        </p> -->
        <div id="text" class="text" style="display:none">
          <div id="text-inner">
            <div id="box">
              <Content />
            </div>
          </div>
        </div>
      </section>


  </body>
</html>

<style>

/*@font-face {
  font-family: myFont;
  src: url(../../assets/handwriting5.ttf);
}*/

/* MOBILE LAYOUT */
@media (max-width: 600px) {

  .object-header {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-template-rows: auto auto;
    grid-template-areas:
      "title prev next random"
      "main  main main main";

    align-items: center;
    gap: 15px;
    padding: 0 5vw;
    justify-content: center;
  }

  .title-image {
    max-width: 100px;
    width: 100%;
    height: auto;
    display: block;
  }

  .title-link {
    grid-area: title;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .nav-link-left {
    grid-area: prev;
    justify-self: center;
  }

  .nav-link-right {
    grid-area: next;
    justify-self: center;
  }

  #nav-link-random {
    grid-area: random;
    justify-self: center;
  }

  .main-image {
    grid-area: main;
    width: 100%;
    height: auto;
    justify-self: center;
  }

  .sticky-note {
    max-width: 100px;
    width: 100%
    height: auto;
    cursor: pointer;
  }

  /* =========================
     IMAGES SECTION (CENTERED)
     ========================= */

  .images {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .images section,
  .card-text,
  .controls {
    width: 100%;
    max-width: 100%;
  }

  .images img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* =========================
     CONTROLS
     ========================= */

  .controls {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    justify-items: center;
    align-items: center;
    gap: 5px;
    padding: 10px 0;
  }

  .side-icon {
    max-width: 60px;
    height: auto;
  }

  .switch {
    position: relative;
    display: inline-block;
    width: 60px;
    height: 34px;
  }

  .switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .slider {
    position: absolute;
    cursor: pointer;
    inset: 0;
    background-color: #ffe600;
    transition: 0.4s;
    transform: scale(1.2);
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 26px;
    width: 26px;
    left: 4px;
    bottom: 4px;
    background-color: rgb(51, 0, 255);
    transition: 0.4s;
  }

  input:checked + .slider {
    background-color: #ff0000;
  }

  input:checked + .slider:before {
    transform: translateX(26px);
  }

  .slider.round {
    border-radius: 34px;
  }

  .slider.round:before {
    border-radius: 50%;
  }

  /* =========================
     TEXT / CARD AREA
     ========================= */

  .text {
    font-family: "Georgia", serif;
    text-align: justify;
    text-justify: inter-word;
    width: 100%;
  }

  #text-inner {
    width: 100%;
  }

  #box {
    width: 100%;
    max-width: 500px;
    margin: 20px auto;
    padding: 12px;
    box-sizing: border-box;
  }

  .text p {
    margin: 0;
    padding: 8px;
    line-height: 1.6;
  }

  section img {
    width: 100%;
    height: auto;
    display: block;
  }
}

/* LAPTOP LAYOUT */
@media (min-width: 601px) {

  .main-image {
    grid-column: 3;
    justify-self: center;
    /*max-width: 180px;*/
    width: 180px;
    height: auto;
    justify-self: center;
  }

  
  .images {
  display: grid;
  /*grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));*/
  grid-template-columns: auto;
  grid-template-rows: auto auto auto;
  gap: <'row-gap'> 0px <'column-gap'> 0px ;
  padding: 5vw;
  }

  .left,
  .right {
    justify-self: center;
  }

.object-header {
  display: grid;
  grid-template-columns: auto auto auto auto auto;
  align-items: center;
  gap: 8vw;
  padding: 20px 6vw 0 6vw;
}



.title-image {
  max-width: 100px;
  width: 100%;
  height: auto;
  justify-self: center;
}

.sticky-note {
  max-width: 100px;
  height: auto;
  justify-self: center;
  cursor: pointer;
}

.left {
  justify-self: start;
}

.right {
  justify-self: end;
}

.nav-link {
  font-size: clamp(0.8rem, 2vw, 1.2rem);
}

.controls {
  display: grid;
  grid-template-columns: auto auto auto;
  justify-items: center;
  align-items: center;
  padding: 0 5vw 0 5vw;
  gap: 3px;
}

.side-icon {
  width: 100%;
  max-width: 40px;
  height: auto;
  justify-self: center;
}

.left-icon {
  grid-column: 2;
}

.right-icon {
  grid-column: 4;
}

.slider {
  grid-column: 3;
}

.images {
  display: grid;
  /*grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));*/
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: auto auto auto;
  gap: <'row-gap'> 0px <'column-gap'> 0px ;
  padding: 5vw;
}

section img {
  width: 100%;
  height: auto;
  display: block;
}

.images section:nth-of-type(1) {
  grid-column: 1;
  grid-row: 2;
}

.images section:nth-of-type(2) {
  grid-column: 2;
  grid-row: 2;
}

.card-text {
  grid-column: 2;
  grid-row: 2;
  position: relative;
}

.card-text img,
