---
import { getCollection, render } from 'astro:content';
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const gallery = await getCollection('gallery');

  return gallery.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const BASE = import.meta.env.BASE_URL;

const object_number = 16;
const { item } = Astro.props;

const slug = item.id;
const { Content } = await render(item);

const match = slug.match(/\d+$/);
const num = match ? parseInt(match[0]) : null;

let prev;
prev = num - 1;
if (prev < 10) {
  prev = num && num > 1 ? `object-0${num - 1}` : null;
} else {
  prev = num && num > 1 ? `object-${num - 1}` : null;
}

let next;
next = num + 1;
if (next < 10) {
  next = num ? `object-0${num + 1}` : null;
} else {
  next = num ? `object-${num + 1}` : null;
}

if (num == 1) {
  prev = `object-${object_number}`;
}
if (num == object_number) {
  next = "object-01";
}

const note_colours = ["y", "b", "g", "p"].sort(() => Math.random() - 0.5);

const [colour1, colour2, colour3] = note_colours;

const main = `${BASE}gallery/${slug}/main.webp`;
const portrait = `${BASE}gallery/${slug}/portrait.webp`;
const card = `${BASE}gallery/${slug}/card.webp`;
---

<Layout>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
  </head>

  <body>
    <script define:vars={{ num, object_number }}>
      window.doRandom = function () {
        let randomNumber;

        do {
          randomNumber = Math.floor(Math.random() * object_number) + 1;
        } while (randomNumber === num);

        if (randomNumber < 10) {
          randomNumber = "0" + randomNumber;
        }

        const randomPage = "object-" + randomNumber;
        window.location.href = `${BASE}gallery/${randomPage}`;
      };

      window.doCheck = function () {
        console.log("doCheck running");
        var checkBox = document.getElementById("myCheck");
        var text = document.getElementById("text");

        if (checkBox.checked == true) {
          text.style.display = "block";
          card.style.display = "none";
        } else {
          text.style.display = "none";
          card.style.display = "block";
        }
      };
    </script>

    <header class="object-header">
      <a href={BASE} class="title-link">
        <img src={`${BASE}title.webp`} class="title-image" />
      </a>

      <a href={`${BASE}gallery/${prev}`} class="nav-link-left">
        <img src={`${BASE}prev_${colour2}.webp`} class="sticky-note" />
      </a>

      <img src={main} class="main-image" />

      <a href={`${BASE}gallery/${next}`} class="nav-link-right">
        <img src={`${BASE}next_${colour3}.webp`} class="sticky-note" />
      </a>

      <div id="nav-link-random">
        <img
          src={`${BASE}RANDOM_${colour1}.webp`}
          class="sticky-note"
          onclick="doRandom()"
        />
      </div>
    </header>

    <div class="images">
      <div class="controls">
        <img src={`${BASE}mspaint2.webp`} class="side-icon" />

        <label class="switch">
          <input type="checkbox" id="myCheck" onclick="doCheck()" />
          <span class="slider round"></span>
        </label>

        <img src={`${BASE}mspaint1.webp`} class="side-icon" />
      </div>

      <section class="portrait">
        <img src={portrait} />
      </section>

      <section class="card-text">
        <img src={card} id="card" />

        <div id="text" class="text" style="display:none">
          <div id="text-inner">
            <div id="box">
              <Content />
            </div>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>

<style>

/* MOBILE LAYOUT */
@media (max-width: 600px) {

  body {
    margin: 0;
    padding: 0;
  }

  .object-header {
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto;
    grid-template-areas:
      "title prev . next random"
      "main main main main main";

    align-items: center;
    gap: 5px;
    padding: 0 5vw;
  }

  .main-image {
    grid-area: main;
    width: 100%;
    height: auto;
  }

  .images {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    padding: 0 4vw;
  }

  .images section,
  .card-text,
  .controls {
    width: 100%;
    max-width: 100%;
  }

  .images img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* CONTROLS FIXED */
  .controls {
    display: grid;
    grid-template-columns: auto auto auto;
    justify-content: center;
    align-items: center;

    padding: 0;
    gap: 6px;
    width: 100%;
  }

  .side-icon {
    max-width: 60px;
    height: auto;
  }

  /* TEXT / CARD */
  #text-inner {
    padding: 4px;
    max-width: 100%;
  }

  #box {
    padding: 10px;
    max-width: 100%;
    margin: 10px 0;
  }

  .text {
    display: flex;
    justify-content: center;
    text-align: justify;
    font-family: "Georgia", serif;
  }

  .text p {
    max-width: 100%;
    margin: 0;
    padding: 8px;
  }

  section img {
    width: 100%;
    height: auto;
    display: block;
  }
}

</style>
</Layout>