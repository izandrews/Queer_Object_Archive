---
import Layout from "../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
---
<Layout>
<a href={BASE} class="title-link" ><img src={`${BASE}title.webp`} alt="Queer Object Archive" class="title-image" /></a>
<div id="text">
     <div id="text-inner">
         <div id="box">
			<h1>QUEER OBJECT ARCHIVE</h1>
            
			<p>Q.O.A. is an online photography archive of queer people and the objects they cherish. </p>
    
		</div>
	</div>
</div>



</Layout>


<style>

    .title-image{
        display:block;
        margin-left:auto;
        margin-right:auto;
        width: 80px;
    }

	#text {
    font-family: "Georgia", serif;
    text-justify: left;
    width: 100%;
    font-size: medium;
  }


#text-inner {
  padding: 1rem;
  max-width: 85%;
  margin: 0 auto; /* centers the parent too */
}

#box {
  padding: 1.5rem;
  border: 2px double black;
  border-radius: 0px;
  justify-content: center;

  max-width: 95%;
  box-sizing: border-box;
  margin: 2rem auto;
}